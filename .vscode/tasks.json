
{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "Compile Student_Management_System",

      "type": "shell",

      "command": "javac",

      "args": [
        "-cp",
        "lib/mysql-connector-j-9.7.0/mysql-connector-j-9.7.0.jar",

        "-d",
        "bin",

        "src/db/DBConnection.java",
        "src/model/Student.java",
        "src/controller/StudentController.java",
        "src/view/StudentView.java",
        "src/Main.java"
      ],

      "group": {
        "kind": "build",
        "isDefault": true
      },

      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },

      "problemMatcher": []
    },

    {
      "label": "Run Student Management System",

      "type": "shell",

      "command": "java",

      "args": [
        "-cp",
        "bin;lib/mysql-connector-j-9.7.0/mysql-connector-j-9.7.0.jar",

        "Main"
      ],

      "group": {
        "kind": "test",
        "isDefault": true
      },

      "dependsOn": "Compile Student Management System",

      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    }
  ]
}
